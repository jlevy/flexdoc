{
  "$defs": {
    "AnnotationSetEntry": {
      "additionalProperties": false,
      "description": "One annotation with a selector relative to its enclosing annotation set.",
      "properties": {
        "body": {
          "anyOf": [
            {
              "$ref": "#/$defs/TextBody"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "captured_text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Captured Text"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "motivations": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Motivations",
          "type": "array"
        },
        "provenance": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Provenance",
          "type": "object"
        },
        "style": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Style"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        },
        "target": {
          "anyOf": [
            {
              "discriminator": {
                "mapping": {
                  "point": "#/$defs/PointSelector",
                  "section": "#/$defs/SectionSelector",
                  "span": "#/$defs/SpanSelector"
                },
                "propertyName": "type"
              },
              "oneOf": [
                {
                  "$ref": "#/$defs/SpanSelector"
                },
                {
                  "$ref": "#/$defs/PointSelector"
                },
                {
                  "$ref": "#/$defs/SectionSelector"
                }
              ]
            },
            {
              "type": "null"
            }
          ],
          "title": "Target"
        }
      },
      "required": [
        "id",
        "motivations",
        "target"
      ],
      "title": "AnnotationSetEntry",
      "type": "object"
    },
    "DocRef": {
      "description": "A non-empty document locator. Parsing and serialization perform no I/O.",
      "title": "DocRef",
      "type": "string"
    },
    "HeadingAnchor": {
      "additionalProperties": false,
      "description": "Quote and position evidence for one complete CommonMark heading.",
      "properties": {
        "exact": {
          "title": "Exact",
          "type": "string"
        },
        "prefix": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prefix"
        },
        "start": {
          "anyOf": [
            {
              "maximum": 9007199254740991,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start"
        },
        "suffix": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Suffix"
        }
      },
      "required": [
        "exact"
      ],
      "title": "HeadingAnchor",
      "type": "object"
    },
    "JsonValue": {},
    "NodeModel": {
      "description": "Serialization model for a single node. Mirrors the runtime `Node` dataclass\nwith JSON-friendly field types. `source_span` is a `{start, end}` object\n(or null for unlocatable nodes like reference links).",
      "properties": {
        "attrs": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Attrs",
          "type": "object"
        },
        "children": {
          "items": {
            "type": "string"
          },
          "title": "Children",
          "type": "array"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "title": "Kind",
          "type": "string"
        },
        "layer": {
          "title": "Layer",
          "type": "string"
        },
        "parent": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parent"
        },
        "source_span": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceSpan"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Text"
        }
      },
      "required": [
        "id",
        "kind",
        "layer"
      ],
      "title": "NodeModel",
      "type": "object"
    },
    "PointAffinity": {
      "description": "The side of a point that owns its identity across insertions.",
      "enum": [
        "before",
        "after"
      ],
      "title": "PointAffinity",
      "type": "string"
    },
    "PointSelector": {
      "additionalProperties": false,
      "description": "A zero-width source boundary with affinity and recovery context.",
      "properties": {
        "affinity": {
          "$ref": "#/$defs/PointAffinity"
        },
        "position": {
          "anyOf": [
            {
              "maximum": 9007199254740991,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Position"
        },
        "prefix": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prefix"
        },
        "suffix": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Suffix"
        },
        "type": {
          "const": "point",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type",
        "affinity"
      ],
      "title": "PointSelector",
      "type": "object"
    },
    "SectionSelector": {
      "additionalProperties": false,
      "description": "A complete CommonMark heading section, including nested subsections.",
      "properties": {
        "end_anchor": {
          "anyOf": [
            {
              "$ref": "#/$defs/HeadingAnchor"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "start_anchor": {
          "$ref": "#/$defs/HeadingAnchor"
        },
        "syntax": {
          "const": "commonmark",
          "title": "Syntax",
          "type": "string"
        },
        "type": {
          "const": "section",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type",
        "syntax",
        "start_anchor"
      ],
      "title": "SectionSelector",
      "type": "object"
    },
    "SourceInfoV2": {
      "additionalProperties": false,
      "description": "DocGraph v0.2 source metadata that binds embedded bare selectors.",
      "properties": {
        "document": {
          "$ref": "#/$defs/DocRef"
        },
        "format": {
          "title": "Format",
          "type": "string"
        },
        "offset_unit": {
          "const": "unicode_code_points",
          "default": "unicode_code_points",
          "title": "Offset Unit",
          "type": "string"
        },
        "sha256": {
          "title": "Sha256",
          "type": "string"
        },
        "source_hash": {
          "title": "Source Hash",
          "type": "string"
        },
        "text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Text"
        }
      },
      "required": [
        "format",
        "sha256",
        "document",
        "source_hash"
      ],
      "title": "SourceInfoV2",
      "type": "object"
    },
    "SourceSpan": {
      "description": "A `[start, end)` span in Unicode code points.",
      "properties": {
        "end": {
          "title": "End",
          "type": "integer"
        },
        "start": {
          "title": "Start",
          "type": "integer"
        }
      },
      "required": [
        "start",
        "end"
      ],
      "title": "SourceSpan",
      "type": "object"
    },
    "SpanSelector": {
      "additionalProperties": false,
      "description": "A non-empty arbitrary source range anchored by exact text and optional context.",
      "properties": {
        "exact": {
          "title": "Exact",
          "type": "string"
        },
        "prefix": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prefix"
        },
        "start": {
          "anyOf": [
            {
              "maximum": 9007199254740991,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start"
        },
        "suffix": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Suffix"
        },
        "type": {
          "const": "span",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type",
        "exact"
      ],
      "title": "SpanSelector",
      "type": "object"
    },
    "TextBody": {
      "additionalProperties": false,
      "description": "A discriminated plain-text annotation body.",
      "properties": {
        "type": {
          "const": "text",
          "title": "Type",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "type",
        "value"
      ],
      "title": "TextBody",
      "type": "object"
    },
    "Views": {
      "description": "Derived view indexes: arrays of node ids for common projections.",
      "properties": {
        "blocks": {
          "items": {
            "type": "string"
          },
          "title": "Blocks",
          "type": "array"
        },
        "links": {
          "items": {
            "type": "string"
          },
          "title": "Links",
          "type": "array"
        },
        "paragraphs": {
          "items": {
            "type": "string"
          },
          "title": "Paragraphs",
          "type": "array"
        },
        "sentences": {
          "items": {
            "type": "string"
          },
          "title": "Sentences",
          "type": "array"
        },
        "toc": {
          "items": {
            "type": "string"
          },
          "title": "Toc",
          "type": "array"
        }
      },
      "title": "Views",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Explicit annotation-bearing DocGraph projection; v0.1 remains unchanged.",
  "properties": {
    "annotations": {
      "items": {
        "$ref": "#/$defs/AnnotationSetEntry"
      },
      "title": "Annotations",
      "type": "array"
    },
    "layout": {
      "items": {},
      "title": "Layout",
      "type": "array"
    },
    "nodes": {
      "items": {
        "$ref": "#/$defs/NodeModel"
      },
      "title": "Nodes",
      "type": "array"
    },
    "provenance": {
      "items": {},
      "title": "Provenance",
      "type": "array"
    },
    "schema": {
      "const": "DocGraph/v0.2",
      "default": "DocGraph/v0.2",
      "title": "Schema",
      "type": "string"
    },
    "source": {
      "$ref": "#/$defs/SourceInfoV2"
    },
    "views": {
      "$ref": "#/$defs/Views"
    }
  },
  "required": [
    "source",
    "nodes",
    "views",
    "annotations"
  ],
  "title": "DocGraphV2",
  "type": "object"
}
